{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "POSTGRES_VERSION",
    "POSTGRES_PORT",
    "POSTGRES_USER",
    "POSTGRES_PASSWORD",
    "POSTGRES_DB",
    "DB_SCHEMA",
    "API_PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "docs/.vitepress/dist/**",
        "storybook-static/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "API_PORT"
      ]
    },
    "lint": {},
    "format": {
      "cache": false
    },
    "generate-openapi": {
      "cache": false
    },
    "check-types": {},
    "test": {
      "dependsOn": [
        "^build"
      ]
    }
  }
}