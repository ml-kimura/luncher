{
  "name": "luncher",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=web --filter=api",
    "ui:dev": "pnpm --filter=@packages/ui dev",
    "ui:build": "pnpm --filter=@packages/ui build",
    "lint": "turbo run lint && pnpm lint:scripts",
    "lint:scripts": "eslint scripts --cache --cache-location node_modules/.cache/eslint-scripts",
    "lint:scripts:fix": "eslint scripts --fix --cache --cache-location node_modules/.cache/eslint-scripts",
    "format": "turbo run format",
    "api:gen:openapi": "pnpm --filter=api gen:openapi",
    "api:sync:messages": "pnpm --filter=api sync:messages",
    "api:copy:artifacts": "pnpm --filter=api copy:artifacts",
    "web:sync:messages": "pnpm --filter=web sync:messages",
    "web:copy:artifacts": "pnpm --filter=web copy:artifacts",
    "batch:sync:messages": "pnpm --filter=batch sync:messages",
    "batch:copy:artifacts": "pnpm --filter=batch copy:artifacts",
    "specs:dev": "pnpm --filter @docs/specs dev",
    "specs:build": "pnpm --filter @docs/specs build",
    "specs:copy:artifacts": "pnpm --filter @docs/specs copy:artifacts",
    "copy:artifacts": "tsx scripts/copy-artifacts.ts",
    "manual:dev": "pnpm --filter @docs/manual dev",
    "manual:build": "pnpm --filter @docs/manual build",
    "db:pull": "pnpm --filter @packages/db db:pull",
    "db:diff": "pnpm --filter @packages/db db:diff",
    "db:apply": "pnpm --filter @packages/db db:apply",
    "db:status": "pnpm --filter @packages/db db:status",
    "db:erd": "pnpm --filter @packages/db db:erd",
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "commitlint": "commitlint --edit",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "version:check": "tsx scripts/version-packages.ts check",
    "version:set": "tsx scripts/version-packages.ts set",
    "version:bump": "tsx scripts/version-packages.ts bump"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,scss,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@packages/eslint-config": "workspace:*",
    "@packages/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "turbo": "^2.9.9",
    "typescript-eslint": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ml-kimura/luncher.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ml-kimura/luncher/issues"
  },
  "homepage": "https://github.com/ml-kimura/luncher#readme"
}
