{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_PUBLIC_API_URL=http://localhost:8787 next dev",
    "build": "next build",
    "start": "next start",
    "sync:messages": "tsx scripts/sync-message-definitions.ts",
    "copy:artifacts": "tsx scripts/copy-messages-to-public.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@packages/ui": "workspace:*",
    "next": "^16.2.3",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@packages/eslint-config": "workspace:*",
    "@packages/tsconfig": "workspace:*",
    "@playwright/test": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "jsdom": "catalog:",
    "vitest": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
