{
  "name": "@packages/tsconfig",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "lint": "eslint eslint.config.mjs --cache --cache-location node_modules/.cache/eslint",
    "lint:fix": "eslint eslint.config.mjs --fix --cache --cache-location node_modules/.cache/eslint",
    "format": "prettier --write \"**/*.json\"",
    "format:check": "prettier --check \"**/*.json\""
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:"
  },
  "files": [
    "base.json",
    "node.json",
    "nextjs.json"
  ],
  "exports": {
    "./base": "./base.json",
    "./node": "./node.json",
    "./nextjs": "./nextjs.json"
  }
}