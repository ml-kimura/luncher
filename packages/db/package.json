{
  "name": "@packages/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "db:pull": "drizzle-kit pull && tsx fix-drizzle.ts && prettier --write \"**/*.ts\"",
    "db:diff": "atlas migrate diff --env local",
    "db:apply": "atlas migrate apply --env ${ATLAS_ENV:-local}",
    "db:status": "atlas migrate status --env ${ATLAS_ENV:-local}",
    "db:erd": "tsx erd.ts",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint",
    "lint:fix": "eslint . --fix --cache --cache-location node_modules/.cache/eslint",
    "format": "prettier --write ."
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@packages/eslint-config": "workspace:*",
    "@packages/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "dotenv": "catalog:",
    "drizzle-kit": "^0.31.10",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  }
}